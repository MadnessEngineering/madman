{
  "name": "mad-tinker",
  "description": "An overengineering communication mode. Expands ideas, overengineers for robustness, and misses nothing.",
  "author": {
    "name": "Julius Brussee",
    "url": "https://github.com/JuliusBrussee"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/tinker-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading tinker mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/tinker-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking tinker mode..."
          }
        ]
      }
    ]
  }
}
